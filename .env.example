# ── SSH tunnel ──────────────────────────────────────────────
SSH_HOST=192.168.25.15
SSH_PORT=22
SSH_USERNAME=root
SSH_PASSWORD=your_password_here
# SSH_KEY_FILE=/path/to/private_key.pem   # alternative to password

# ── PostgreSQL (internal address behind SSH) ─────────────────
DB_HOST=192.168.25.15
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ── Ollama models ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OCR_MODEL=glm-ocr
EXTRACTION_MODEL=llama3.1:8b

# ── Extraction backend ───────────────────────────────────────
# "ollama" — local Ollama model (default)
# "gigachat" — GigaChat API via LangChain (OCR still uses Ollama)
EXTRACTION_BACKEND=ollama

# ── GigaChat (only used when EXTRACTION_BACKEND=gigachat) ────
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_CREDENTIALS=your_gigachat_credentials_here
